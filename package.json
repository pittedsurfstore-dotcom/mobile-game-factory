{
  "name": "mobile-game-factory",
  "private": true,
  "version": "0.1.2",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "typecheck": "tsc --noEmit -p apps/mobile/tsconfig.json",
    "lint": "eslint .",
    "test": "jest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "turbo run build",
    "mobile": "pnpm --filter @mgf/mobile start",
    "prepare": "husky"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^29.5.14",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.5",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.3.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "ts-jest": "^29.4.11",
    "turbo": "^2.1.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.60.1"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "ansi-regex": "^5.0.1"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
